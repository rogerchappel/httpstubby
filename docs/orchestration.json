{
  "repo": "https://github.com/rogerchappel/httpstubby",
  "branch": "main",
  "name": "httpstubby",
  "description": "A tiny local-first API stub server from JSON fixtures.",
  "owner": "rogerchappel",
  "keyFiles": [
    "src/index.js",
    "src/server.js",
    "src/init.js",
    "test/server.test.js",
    "scripts/validate.sh",
    "package.json",
    "README.md",
    "docs/PRD.md",
    "docs/TASKS.md",
    "docs/ORCHESTRATION.md",
    "docs/orchestration.json"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/server.js && node --check src/init.js",
    "build": "echo 'No build step required'",
    "smoke": "bash scripts/validate.sh"
  }
}
